# Copy to .env and fill in. Never commit .env — it is gitignored.

# ── Wallets (node scripts/setup.js generates these) ───────────────────────────

# Buyer keypair (base58 secret) — funds PatchBond escrow and signs release/refund on devnet.
# Generate it locally with npm run setup; never paste a key into chat or commit it.
# Fund only its PUBLIC address at https://faucet.solana.com.
BUYER_KEYPAIR_B58=

# Seller keypair (base58 secret) — a distinct party so settlement is a real two-party transfer.
# It only RECEIVES payment, so it needs no funding, UNLESS PROCURE_RAIL=x402 is set (then it also
# spends on the seller's own upstream procurement leg — see PAY.md). (setup.js generates this.)
SELLER_KEYPAIR_B58=

# Seller public key — the x402 payment's payout destination. setup.js sets this to
# SELLER_KEYPAIR_B58's pubkey. If unset, settle() self-pays the buyer (one-wallet demo; not a real
# two-party transfer).
WALLET=

SOLANA_RPC_URL=https://api.devnet.solana.com

# Optional GitHub connector. Public repositories need no token. For private repositories,
# use a fine-grained token with only Contents: read, Pull requests: write, Checks: read.
# Keep it local in .env; never paste it into chat or commit it.
GITHUB_TOKEN=
PATCHBOND_PORT=4173

# ── TxLINE (optional) ─────────────────────────────────────────────────────────
# The proxy subscribes the buyer wallet to the free World Cup tier on its own, so you don't need to
# set these. `npm run mint` (examples/txodds) writes TXLINE_API_KEY here for the standalone TxLineClient.
TXLINE_API_KEY=
TXLINE_BASE_URL=

# Override the TxLINE devnet ids if TxODDS rotates them (defaults are baked into the proxy):
TXLINE_PROGRAM=          # subscription program id (default 6pW64…P2J)
TXLINE_MINT=             # treasury token mint    (default 4Zao8o…EokRG)
