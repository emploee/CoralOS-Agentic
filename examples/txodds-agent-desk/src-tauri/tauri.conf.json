{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TxODDS Agent Desk",
  "version": "0.1.0",
  "identifier": "sh.pay.txodds-agent-desk",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "windows": [
      {
        "title": "TxODDS Agent Desk",
        "width": 1200,
        "height": 820,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8801 http://127.0.0.1:8801 http://localhost:4000 http://localhost:4600; style-src 'self' 'unsafe-inline'; img-src 'self' data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.ico", "icons/icon.png"]
  }
}
